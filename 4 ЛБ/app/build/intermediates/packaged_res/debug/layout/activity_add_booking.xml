<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_add_booking"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Client:"
        android:textSize="14sp"
        android:textColor="#777777"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerClient"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/btn_dropdown"
        android:spinnerMode="dropdown" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Room (Only Available):"
        android:textSize="14sp"
        android:textColor="#777777"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerRoom"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/btn_dropdown"
        android:spinnerMode="dropdown" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Check-In Date (YYYY-MM-DD):"
        android:textSize="14sp"
        android:textColor="#777777"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etCheckIn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:hint="e.g. 2026-06-01"
        android:inputType="date"
        android:padding="10dp"
        android:background="@android:drawable/editbox_background_normal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Check-Out Date (YYYY-MM-DD):"
        android:textSize="14sp"
        android:textColor="#777777"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etCheckOut"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="24dp"
        android:hint="e.g. 2026-06-08"
        android:inputType="date"
        android:padding="10dp"
        android:background="@android:drawable/editbox_background_normal" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Book Room"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:textAllCaps="false"
        android:backgroundTint="#6200EE"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Cancel"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:backgroundTint="#888888"
        android:textColor="#FFFFFF" />

</LinearLayout>
