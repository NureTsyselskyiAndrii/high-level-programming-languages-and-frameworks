<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center_horizontal"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✖ Добуток чисел"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Введіть два числа та натисніть «Обчислити»"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginBottom="28dp"/>

    <EditText
        android:id="@+id/etNum1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Перше число"
        android:inputType="numberDecimal|numberSigned"
        android:layout_marginBottom="12dp"
        android:padding="12dp"
        android:background="@android:color/white"/>

    <EditText
        android:id="@+id/etNum2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Друге число"
        android:inputType="numberDecimal|numberSigned"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:background="@android:color/white"/>

    <TextView
        android:id="@+id/tvFormula"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="#888888"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnCalc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Обчислити добуток"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnClear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Очистити"
        android:backgroundTint="#888888"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnGoToGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎮 Перейти до гри"
        android:backgroundTint="#4CAF50"/>

</LinearLayout>
